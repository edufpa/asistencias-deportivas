generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          UserRole      @default(COACH)
  accountStatus AccountStatus @default(APPROVED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  convocatorias      Convocatoria[]
  convocatoriasAsCoach      Convocatoria[] @relation("ConvocatoriaCoach")
  convocatoriasAsAssistant1 Convocatoria[] @relation("ConvocatoriaAssistant1")
  convocatoriasAsAssistant2 Convocatoria[] @relation("ConvocatoriaAssistant2")
  convocatoriasAsDelegate   Convocatoria[] @relation("ConvocatoriaDelegate")
  cortes             ConvocatoriaPlayer[] @relation("CortadoPor")
  attendanceSessions AttendanceSession[]
  testsCreated       Test[]
  testEvaluations    TestEvaluation[]
  matchesCreated     Match[]
  activityLogs       ActivityLog[]
  linkedPlayers      UserPlayer[]
  passwordResetTokens PasswordResetToken[]
  calendarEvents     CalendarEvent[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  SUPER_ADMIN
  COMISION
  COACH
  PARENT
}

model UserPlayer {
  id       String @id @default(cuid())
  userId   String
  playerId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([userId, playerId])
  @@map("user_players")
}

model Player {
  id                   String           @id @default(cuid())
  firstName            String
  paternalLastName     String           @map("lastName")
  maternalLastName     String           @default("")
  documentType         DocumentType     @default(DNI)
  documentId           String           @unique
  birthDate            DateTime
  gender               Gender           @default(MALE)
  membershipStatus     MembershipStatus @default(NO_ASOCIADO)
  membershipCardNumber String?
  federationCode       String?
  playerStatus         PlayerStatus     @default(ACTIVE)
  teamJoinDate         DateTime?        @db.Date
  homeAddress          String?
  contactPhone         String?
  playerEmail          String?
  fatherName           String?
  fatherEmail          String?
  fatherPhone          String?
  motherName           String?
  motherEmail          String?
  motherPhone          String?
  tutorName            String?
  tutorEmail           String?
  tutorPhone           String?
  photoUrl                 String?
  documentPhotoFrontUrl    String?
  documentPhotoBackUrl     String?
  educationalCenter    String?
  educationLevel       String?
  absencePermissionContact String?
  medicalInfo          String?
  bloodType            String?
  allergies            String?
  epsInsurance         String?
  observations         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  convocatorias      ConvocatoriaPlayer[]
  attendanceRecords  AttendanceRecord[]
  testEvaluations    TestEvaluation[]
  matchStats         MatchPlayerStat[]
  matchRosterEntries MatchRosterPlayer[]
  linkedUsers        UserPlayer[]

  @@map("players")
}

model ClubRegistrationLink {
  id        String   @id @default("club")
  token     String   @unique @default(cuid())
  updatedAt DateTime @updatedAt

  @@map("club_registration_link")
}

enum DocumentType {
  DNI
  PASAPORTE
  CARNET_EXTRANJERIA
}

enum MembershipStatus {
  ASOCIADO
  NO_ASOCIADO
}

enum PlayerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  MIXED
}

model Convocatoria {
  id          String             @id @default(cuid())
  name        String
  description String?
  gender      Gender             @default(MIXED)
  category    Category           @default(SUB16)
  startDate   DateTime           @default(now())
  status      ConvocatoriaStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  createdBy   String
  creator     User               @relation(fields: [createdBy], references: [id])

  coachUserId      String?
  coachUser        User? @relation("ConvocatoriaCoach", fields: [coachUserId], references: [id])
  assistant1UserId String?
  assistant1User   User? @relation("ConvocatoriaAssistant1", fields: [assistant1UserId], references: [id])
  assistant2UserId String?
  assistant2User   User? @relation("ConvocatoriaAssistant2", fields: [assistant2UserId], references: [id])
  delegateUserId   String?
  delegateUser     User? @relation("ConvocatoriaDelegate", fields: [delegateUserId], references: [id])

  players     ConvocatoriaPlayer[]
  sessions    AttendanceSession[]
  matches     Match[]

  @@map("convocatorias")
}

enum ConvocatoriaStatus {
  ACTIVE
  CLOSED
}

model ConvocatoriaPlayer {
  id            String                   @id @default(cuid())
  status        ConvocatoriaPlayerStatus @default(ACTIVE)
  capNumber     Int?
  cutDate       DateTime?
  cutReason     String?
  joinedAt      DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  convocatoriaId String
  convocatoria   Convocatoria @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  cutById String?
  cutBy   User?   @relation("CortadoPor", fields: [cutById], references: [id])

  @@unique([convocatoriaId, playerId])
  @@unique([convocatoriaId, capNumber])
  @@map("convocatoria_players")
}

enum ConvocatoriaPlayerStatus {
  ACTIVE
  CUT
}

model AttendanceSession {
  id          String      @id @default(cuid())
  sessionDate DateTime    @db.Date
  sessionType SessionType
  category    Category?
  createdAt   DateTime    @default(now())

  convocatoriaId String?
  convocatoria   Convocatoria? @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  records AttendanceRecord[]

  @@unique([convocatoriaId, sessionDate, sessionType])
  @@unique([category, sessionDate, sessionType])
  @@map("attendance_sessions")
}

enum Category {
  SUB10
  SUB12
  SUB14
  SUB16
  SUB18
  OPEN
}

enum SessionType {
  TURNO_MANANA
  TURNO_TARDE
  PESAS
}

model AttendanceRecord {
  id               String          @id @default(cuid())
  status           AttendanceStatus
  performanceScore Int?
  absenceReason    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  @@unique([sessionId, playerId])
  @@map("attendance_records")
}

enum AttendanceStatus {
  ATTENDED
  ABSENT_JUSTIFIED
  ABSENT_UNJUSTIFIED
}

// ─── TESTS DE EVALUACIÓN ──────────────────────────────────────────────────────

model Test {
  id          String       @id @default(cuid())
  name        String
  unit        String       // "kg", "seg", "m", "rep", etc.
  category    TestCategory @default(NATACION)
  description String?
  higherIsBetter Boolean @default(true) // true = mayor valor = mejor (fuerza); false = menor = mejor (velocidad)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  evaluations TestEvaluation[]

  @@map("tests")
}

enum TestCategory {
  FUERZA
  NATACION
  ANTROPOMETRIA
}

model TestEvaluation {
  id           String   @id @default(cuid())
  value        Float
  evalDate     DateTime @db.Date
  notes        String?
  createdAt    DateTime @default(now())

  testId    String
  test      Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  playerId  String
  player    Player @relation(fields: [playerId], references: [id])

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  @@map("test_evaluations")
}

// ─── PARTIDOS ─────────────────────────────────────────────────────────────────

model Match {
  id               String    @id @default(cuid())
  matchDate        DateTime  @db.Date
  matchType        MatchType
  opponent         String?
  location         String?
  homeScore        Int?
  awayScore        Int?
  quarterDuration  Int?      // minutes per quarter
  notes            String?
  // Team evaluations 1-4
  evalOverall      Int?
  evalAttack       Int?
  evalDefense      Int?
  evalFinishing    Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  convocatoriaId String?
  convocatoria   Convocatoria? @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  playerStats MatchPlayerStat[]
  rosterPlayers MatchRosterPlayer[]

  @@map("matches")
}

model MatchRosterPlayer {
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  @@id([matchId, playerId])
  @@map("match_roster_players")
}

enum MatchType {
  OFFICIAL
  PRACTICE
}

// ─── LOGS DE ACTIVIDAD ────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g. PLAYER_CREATED, CONV_CREATED, PLAYER_CUT, ATTENDANCE_SAVED
  entity    String   // player, convocatoria, attendance, match, test, user
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model MatchPlayerStat {
  id                  String @id @default(cuid())
  quarter             Int
  goals               Int    @default(0)
  missedShots         Int    @default(0)
  exclusionsGenerated Int    @default(0)
  exclusionsAgainst   Int    @default(0)
  penaltiesGenerated  Int    @default(0)
  penaltiesAgainst    Int    @default(0)
  assists             Int    @default(0)
  badPasses           Int    @default(0)
  counterattacks      Int    @default(0)
  blocksSteals        Int    @default(0)
  minutesPlayed       Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId, quarter])
  @@map("match_player_stats")
}

// ─── CALENDARIO DE ACTIVIDADES ────────────────────────────────────────────────

enum EventCategory {
  TORNEO
  PARTIDO_PRACTICA
  INSCRIPCION
  CONGRESILLO
  PAGO_INSCRIPCION
  REUNION_PAPAS
  REUNION_ENTRENADORES
  REUNION_COMISION
  OTRAS
}

enum EventAccessLevel {
  COMISION
  COACH
  PARENT
}

enum EventLocation {
  MEET
  OFICINA
  SALON_NAUTICO
  OTRO
}

model CalendarEvent {
  id           String             @id @default(cuid())
  title        String
  description  String?
  location     EventLocation?
  locationOther String?
  startDate    DateTime           @db.Date
  endDate      DateTime?          @db.Date
  startTime    String?
  endTime      String?
  allDay       Boolean            @default(true)
  category     EventCategory
  accessLevels EventAccessLevel[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@map("calendar_events")
}
